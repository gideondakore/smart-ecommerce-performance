              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Staff\",\n  \"lastName\": \"Member\",\n  \"email\": \"staff@example.com\",\n  \"password\": \"StaffPass123\",\n  \"role\": \"STAFF\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
