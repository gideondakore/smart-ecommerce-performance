    {
      "name": "RBAC Tests",
      "description": "Tests role-based access control enforcement",
      "item": [
        {
          "name": "CUSTOMER cannot access admin users list",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Access denied for CUSTOMER', function() {",
                  "    pm.expect(pm.response.code).to.eql(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          },
          "description": "Login as CUSTOMER first, then try accessing admin-only users list."
        },
        {
          "name": "Unauthenticated cannot access protected endpoints",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unauthenticated returns 401/403', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "profile"]
            }
          }
        },
        {
          "name": "STAFF can view all orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('STAFF can access orders', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          },
          "description": "Login as STAFF first, then access orders list."
        }
      ]
    },
    {
      "name": "CSRF Demo",
      "description": "Demonstrates CSRF protection on form-based endpoints",
      "item": [
        {
          "name": "Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.token) {",
                  "        pm.collectionVariables.set('csrfToken', jsonData.token);",
                  "    }",
                  "    pm.test('CSRF token retrieved', function() {",
                  "        pm.expect(jsonData.token).to.be.a('string');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/csrf-demo/token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "csrf-demo", "token"]
            }
          }
        },
        {
          "name": "Submit Feedback (with CSRF token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Feedback submitted with CSRF token', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('success');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              { "key": "X-CSRF-TOKEN", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "message",
                  "value": "This is a test feedback message",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/csrf-demo/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "csrf-demo", "feedback"]
            }
          }
        },
        {
          "name": "Submit Feedback (without CSRF token - should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Request rejected without CSRF token', function() {",
                  "    pm.expect(pm.response.code).to.eql(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "message",
                  "value": "This should be rejected",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/csrf-demo/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "csrf-demo", "feedback"]
            }
          }
        }
      ]
    },
