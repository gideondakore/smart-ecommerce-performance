              "script": {
                "exec": [
                  "pm.test('Token is valid', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.eql(true);",
                  "});"
                ],
